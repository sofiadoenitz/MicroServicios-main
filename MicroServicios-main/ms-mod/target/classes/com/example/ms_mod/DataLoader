@Component
public class DataLoader implements CommandLineRunner{
    @Autowired
    private ModRepository repo;

    @Override
    public void run(String... args) throws Exception {
    if (repo.count() == 0) {
        Faker faker = new Faker();
        for (int i = 0; i < 15; i++) {
            Mod mod = new Mod();
            mod.setNombre(faker.name().fullName());
            mod.setTelefono(faker.phoneNumber().cellPhone());
            repo.save(mod);
        }
    }
    repo.flush();
    List<Mod> mods = repo.findAll();
}
}